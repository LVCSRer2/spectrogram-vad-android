<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0D0D0D">

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Start"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF2196F3"
            android:minWidth="100dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ready"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvProb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#FFAAAAAA"
            android:textSize="24sp"
            android:fontFamily="monospace"
            android:minWidth="72dp"
            android:gravity="end" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:tint="#FFAAAAAA" />
    </LinearLayout>

    <!-- Spectrogram -->
    <com.example.spectrogramvad.SpectrogramView
        android:id="@+id/spectrogramView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3" />

    <!-- VAD probability graph -->
    <com.example.spectrogramvad.VadProbView
        android:id="@+id/vadProbView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
